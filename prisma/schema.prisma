// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String    // Hashed password
  phone         String?   // Telefone/Celular
  cpf           String?   @unique // CPF (único)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts      Account[]
  sessions      Session[]
  subscriptions Subscription[]
  exchangeKeys  ExchangeKey[]
  tradingRules  TradingRule[]
  portfolioPositions PortfolioPosition[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Subscription {
  id            String   @id @default(cuid())
  userId        String
  planId        String   // ex.: mensal, anual (catálogo de planos no app)
  planName      String?  // nome exibível (snapshot no momento da compra)
  status        String   // active, cancelled, expired, incomplete, trialing, past_due...
  externalId    String?  @unique // ID da assinatura no Stripe (ex.: sub_...)
  priceCents    Int?     // snapshot do preço (centavos) no momento da criação
  currency      String?  // ex.: brl
  interval      String?  // ex.: month, year
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("subscriptions")
}

model ExchangeKey {
  id        String   @id @default(cuid())
  userId    String
  exchange  String   // binance, coinbase, etc
  apiKey    String   // Encrypted
  secret    String   // Encrypted
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, exchange])
  @@map("exchange_keys")
}

model TradingRule {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  enabled     Boolean  @default(true)
  conditions  Json     // Estrutura de condições
  actions     Json     // Ações a executar
  config      Json?    // Configurações adicionais
  triggerCount Int     @default(0)
  lastTriggered DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("trading_rules")
}

/** Posições manuais da carteira (antes só em localStorage). */
model PortfolioPosition {
  id           String   @id @default(cuid())
  userId       String
  type         String   // crypto | stock | etf | bdr | fii | prediction
  symbol       String
  name         String
  entryDate    DateTime
  entryPrice   Float
  quantity     Float
  currentPrice Float?
  side         String?  // YES | NO (mercados de previsão)
  market       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("portfolio_positions")
}
