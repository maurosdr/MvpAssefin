# WhatsApp Business API (Meta for Developers)
# Get these from: developers.facebook.com → Your App → WhatsApp → API Setup
WHATSAPP_TOKEN=your_meta_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_VERIFY_TOKEN=assefin_wa_verify

# Federal Reserve Economic Data (FRED) API
# Get your key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Polygon.io (Massive.com) API - for US Treasury yields (optional)
MASSIVE_API_KEY=your_polygon_api_key_here

# BrAPI - Brazilian stock market data (quotes, historical, heatmap, etc.)
# Get your key at: https://brapi.dev/
BRAPI_TOKEN=your_brapi_token_here

# Anthropic Claude API - powers the right-side AI sidebar
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Stripe — Checkout (assinaturas em BRL)
# Keys: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
# Webhook signing secret ( Stripe CLI local ou endpoint no Dashboard )
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
# URL pública do app (success/cancel do Checkout)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Crypto cookie encryption (32 bytes base64)
# Used to encrypt exchange/binance keys stored as httpOnly cookies.
EXCHANGE_KEYS_ENCRYPTION_KEY=base64_32_bytes_here
